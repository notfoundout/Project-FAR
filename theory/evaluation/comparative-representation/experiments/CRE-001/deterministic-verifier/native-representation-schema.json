{
  "$id": "https://project-far.local/schemas/cre001-native-representation-v1.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": true,
  "allOf": [
    {
      "if": {
        "properties": {
          "vocabulary": {
            "const": "A"
          }
        }
      },
      "then": {
        "properties": {
          "constructs": {
            "contains": {
              "properties": {
                "kind": {
                  "const": "transformation_schema"
                }
              }
            }
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "vocabulary": {
            "const": "B"
          }
        }
      },
      "then": {
        "properties": {
          "constructs": {
            "contains": {
              "properties": {
                "kind": {
                  "const": "complete_state"
                }
              }
            }
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "vocabulary": {
            "const": "C"
          }
        }
      },
      "then": {
        "properties": {
          "constructs": {
            "contains": {
              "properties": {
                "kind": {
                  "const": "admissible_transition_calculus"
                }
              }
            }
          }
        }
      }
    }
  ],
  "properties": {
    "constructs": {
      "items": {
        "additionalProperties": true,
        "properties": {
          "derived_construct": {
            "type": "string"
          },
          "id": {
            "type": "string"
          },
          "kind": {
            "type": "string"
          },
          "primitive": {
            "enum": [
              "Object",
              "Relation",
              "Transformation",
              "State",
              "Transition",
              "Label",
              "Representation",
              "Representational Structure",
              "Interpretation",
              "Investigation",
              "Calculus"
            ]
          },
          "scenario_path": {
            "type": "string"
          }
        },
        "required": [
          "id",
          "kind",
          "primitive",
          "scenario_path"
        ],
        "type": "object"
      },
      "type": "array"
    },
    "definition_digest": {
      "type": "string"
    },
    "derived_constructs": {
      "items": {
        "required": [
          "id",
          "role"
        ],
        "type": "object"
      },
      "type": "array"
    },
    "native_format": {
      "const": "cre001-atomic-native-representation-v1"
    },
    "scenario_source_sha256": {
      "type": "string"
    },
    "vocabulary": {
      "enum": [
        "A",
        "B",
        "C"
      ]
    },
    "vocabulary_identifier": {
      "type": "string"
    },
    "vocabulary_source_sha256": {
      "type": "string"
    }
  },
  "required": [
    "native_format",
    "vocabulary",
    "vocabulary_identifier",
    "constructs",
    "derived_constructs"
  ],
  "title": "CRE-001 atomic vocabulary-native representation tagged union v1",
  "type": "object"
}
