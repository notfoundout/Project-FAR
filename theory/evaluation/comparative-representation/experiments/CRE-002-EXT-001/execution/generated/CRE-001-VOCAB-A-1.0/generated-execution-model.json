{
  "bounds": {
    "contain_max": 1,
    "dispatch_alpha_max": 1,
    "dispatch_beta_max": 1,
    "halt_max": 1,
    "modification_max": 1,
    "override_max": 1,
    "record_a_max": 1,
    "record_b_max": 1
  },
  "initial_state": {
    "action_history": [],
    "active_rules": [
      "R_confirm",
      "R_dispatch_alpha",
      "R_dispatch_beta",
      "R_override",
      "R_contain",
      "R_modify",
      "R_halt"
    ],
    "booleans": {
      "alarm_confirmed": false,
      "alpha_dispatched": false,
      "beta_dispatched": false,
      "incident_contained": false,
      "manual_override": false,
      "route_alpha_open": true,
      "route_beta_open": true,
      "sensor_a_positive": false,
      "sensor_b_positive": false,
      "system_halted": false
    },
    "evidence_log": [],
    "modification_count": 0,
    "priorities": {
      "R_dispatch_alpha": 50,
      "R_dispatch_beta": 50,
      "R_modify": 80,
      "R_override": 100
    }
  },
  "interleaving": {
    "atomic_transition_effects": true,
    "independent_transitions": [
      "T_record_a",
      "T_record_b"
    ],
    "simultaneous_execution": false
  },
  "invariants": [
    "evidence_log and action_history are append-only and ordered",
    "provenance-sensitive guards require matching source and reliability records",
    "no transition after system_halted=true",
    "modification_count<=1",
    "only T_modify changes rule activation",
    "defeated rules remain represented and historically recoverable",
    "interleaving does not alter atomic transition effects"
  ],
  "outputs": [
    "final_state",
    "ordered_evidence_log",
    "ordered_action_history",
    "final_rule_statuses",
    "nondeterministic_outcomes",
    "priority_defeat_occurred",
    "rule_modification_occurred",
    "terminal_reason",
    "invariant_violation_occurred"
  ],
  "scenario_id": "CRE-002-EXT-001-SCENARIO-1.0",
  "semantic_authority": "VOCABULARY-SEMANTICS-BASELINE-1.1",
  "transitions": [
    {
      "append_history": true,
      "guard": [
        "not previously fired"
      ],
      "id": "T_record_a",
      "nondeterministic_alternatives": [
        {
          "append_evidence": [
            "sensor_a_positive=true",
            "sensor_a",
            "high"
          ],
          "set": {
            "sensor_a_positive": true
          }
        },
        {
          "append_evidence": [
            "sensor_a_positive=false",
            "sensor_a",
            "high"
          ],
          "set": {
            "sensor_a_positive": false
          }
        }
      ]
    },
    {
      "append_history": true,
      "guard": [
        "not previously fired"
      ],
      "id": "T_record_b",
      "nondeterministic_alternatives": [
        {
          "append_evidence": [
            "sensor_b_positive=true",
            "sensor_b",
            "high"
          ],
          "set": {
            "sensor_b_positive": true
          }
        },
        {
          "append_evidence": [
            "sensor_b_positive=false",
            "sensor_b",
            "low"
          ],
          "set": {
            "sensor_b_positive": false
          }
        }
      ]
    },
    {
      "append_history": true,
      "authorization": "R_confirm",
      "guard_expression": "sensor_a_positive=true AND provenance(sensor_a_positive=true,sensor_a,high) AND (sensor_b_positive=true OR manual_override=true)",
      "id": "T_confirm",
      "updates": {
        "alarm_confirmed": true
      }
    },
    {
      "append_history": true,
      "authorization": "R_override",
      "defeats_lower_priority_conflict_for_current_state": true,
      "guard_expression": "provenance(manual_override=true,operator,high)",
      "id": "T_override",
      "updates": {
        "manual_override": true
      }
    },
    {
      "append_history": true,
      "authorization": "R_dispatch_alpha",
      "guard_all": [
        "alarm_confirmed=true",
        "route_alpha_open=true",
        "alpha_dispatched=false",
        "system_halted=false"
      ],
      "id": "T_dispatch_alpha",
      "updates": {
        "alpha_dispatched": true
      }
    },
    {
      "append_history": true,
      "authorization": "R_dispatch_beta",
      "guard_all": [
        "alarm_confirmed=true",
        "route_beta_open=true",
        "beta_dispatched=false",
        "system_halted=false"
      ],
      "id": "T_dispatch_beta",
      "updates": {
        "beta_dispatched": true
      }
    },
    {
      "append_history": true,
      "authorization": "R_modify",
      "guard_all": [
        "alarm_confirmed=true",
        "modification_count=0",
        "exactly_one(alpha_dispatched,beta_dispatched)=true"
      ],
      "id": "T_modify",
      "updates": [
        "deactivate dispatch rule for not-yet-dispatched agent",
        "modification_count:=1",
        "append before/after rule-status record"
      ]
    },
    {
      "append_history": true,
      "authorization": "R_contain",
      "guard_expression": "(alpha_dispatched=true OR beta_dispatched=true) AND alarm_confirmed=true",
      "id": "T_contain",
      "updates": {
        "incident_contained": true
      }
    },
    {
      "append_history": true,
      "authorization": "R_halt",
      "guard_any": [
        "incident_contained=true",
        "deadlock_condition=true"
      ],
      "id": "T_halt",
      "updates": {
        "system_halted": true
      }
    }
  ]
}
