{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/notfoundout/Project-FAR/theory/evaluation/pbts001-independent-replication-response-schema.json",
  "title": "PBTS-001 Independent Replication Response",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "package_id",
    "package_version",
    "run_id",
    "submission_id",
    "replicator_slot",
    "calibration_record_id",
    "protected_input_verification",
    "independence_declaration",
    "tool_disclosure",
    "paired_axis_results",
    "ablation_results",
    "domain_coverage",
    "countermodel_results",
    "hidden_recovery_results",
    "addition_search_results",
    "P8_classification",
    "deviations",
    "nonclaim_acknowledgements",
    "submitted_at"
  ],
  "properties": {
    "schema_version": {"const": "1.0"},
    "package_id": {"const": "PBTS-001-REP-001"},
    "package_version": {"const": "1.0"},
    "run_id": {"const": "PBTS-001-REP-001-RUN-001"},
    "submission_id": {"type": "string", "minLength": 1},
    "replicator_slot": {"enum": ["REP-A", "REP-B", "REP-C"]},
    "calibration_record_id": {"type": "string", "minLength": 1},
    "protected_input_verification": {
      "type": "object",
      "additionalProperties": false,
      "required": ["verified", "verification_method", "mismatches"],
      "properties": {
        "verified": {"type": "boolean"},
        "verification_method": {"type": "string", "minLength": 1},
        "mismatches": {"type": "array", "items": {"type": "string"}}
      }
    },
    "independence_declaration": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "prior_project_role",
        "run001_exposure_before_freeze",
        "communication_with_other_replicators",
        "generated_artifacts_received",
        "unpublished_repair_knowledge_received",
        "organizational_affiliation",
        "funding_or_supervision_conflicts",
        "attestation"
      ],
      "properties": {
        "prior_project_role": {"type": "string"},
        "run001_exposure_before_freeze": {"type": "boolean"},
        "communication_with_other_replicators": {"type": "boolean"},
        "generated_artifacts_received": {"type": "boolean"},
        "unpublished_repair_knowledge_received": {"type": "boolean"},
        "organizational_affiliation": {"type": "string"},
        "funding_or_supervision_conflicts": {"type": "string"},
        "attestation": {"type": "string", "minLength": 20}
      }
    },
    "tool_disclosure": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["tool", "version_or_identity", "purpose", "shared_with_other_replicators"],
        "properties": {
          "tool": {"type": "string", "minLength": 1},
          "version_or_identity": {"type": "string"},
          "purpose": {"type": "string", "minLength": 1},
          "shared_with_other_replicators": {"type": "boolean"}
        }
      }
    },
    "paired_axis_results": {
      "type": "array",
      "minItems": 8,
      "maxItems": 8,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["pair_id", "target_axis", "score", "distinction_preserved", "hidden_recovery", "justification", "failure_or_ambiguity"],
        "properties": {
          "pair_id": {"enum": ["PA-01", "PA-02", "PA-03", "PA-04", "PA-05", "PA-06", "PA-07", "PA-08"]},
          "target_axis": {"enum": ["P1", "P2", "P3", "P4", "P5", "P6", "P7", "P8"]},
          "score": {"enum": ["pass", "partial", "fail", "unknown"]},
          "distinction_preserved": {"enum": ["yes", "partially", "no", "unknown"]},
          "hidden_recovery": {"enum": ["none", "counted", "uncounted", "unknown"]},
          "justification": {"type": "string", "minLength": 20},
          "failure_or_ambiguity": {"type": "string"}
        }
      }
    },
    "ablation_results": {
      "type": "array",
      "minItems": 8,
      "maxItems": 8,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["axis", "outcome", "lost_or_recovered_distinction", "recovery_cost_counted", "justification"],
        "properties": {
          "axis": {"enum": ["P1", "P2", "P3", "P4", "P5", "P6", "P7", "P8"]},
          "outcome": {"enum": ["loss_detected", "recoverable_with_counted_commitment", "hidden_reintroduction", "no_observed_loss", "unknown"]},
          "lost_or_recovered_distinction": {"type": "string", "minLength": 1},
          "recovery_cost_counted": {"type": "boolean"},
          "justification": {"type": "string", "minLength": 20}
        }
      }
    },
    "domain_coverage": {
      "type": "array",
      "minItems": 32,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["case_id", "domain_class", "case_role", "observability", "axes_at_issue", "source_provenance", "candidate_author_involvement", "limitations", "classification"],
        "properties": {
          "case_id": {"type": "string", "minLength": 1},
          "domain_class": {"enum": ["D1", "D2", "D3", "D4", "D5", "D6", "D7", "D8", "D9", "D10", "D11", "D12", "D13", "D14", "D15", "D16"]},
          "case_role": {"enum": ["ordinary_or_representative", "pressure_or_boundary_adjacent"]},
          "observability": {"enum": ["O0", "O1", "O2", "O3", "O4"]},
          "axes_at_issue": {"type": "array", "minItems": 1, "items": {"enum": ["P1", "P2", "P3", "P4", "P5", "P6", "P7", "P8"]}},
          "source_provenance": {"type": "string", "minLength": 1},
          "candidate_author_involvement": {"type": "string"},
          "limitations": {"type": "string"},
          "classification": {"enum": ["covered", "partial", "unknown", "invalid"]}
        }
      }
    },
    "countermodel_results": {
      "type": "array",
      "minItems": 10,
      "maxItems": 10,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["countermodel", "classification", "axes_responsible", "manufactured_preservation_rejected", "justification"],
        "properties": {
          "countermodel": {"enum": ["arbitrary_labeled_transition", "output_equivalent_lookup", "post_hoc_narrative", "hidden_operator", "pure_optimizer", "trivial_universal_encoding", "distributed_reasoning", "self_revision", "continuous_embodied_control", "conflicting_normative_reasons"]},
          "classification": {"enum": ["pass", "partial", "fail", "unknown", "boundary_unresolved"]},
          "axes_responsible": {"type": "array", "items": {"enum": ["P1", "P2", "P3", "P4", "P5", "P6", "P7", "P8"]}},
          "manufactured_preservation_rejected": {"enum": ["yes", "no", "not_applicable", "unknown"]},
          "justification": {"type": "string", "minLength": 20}
        }
      }
    },
    "hidden_recovery_results": {
      "type": "array",
      "minItems": 8,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["recovery_id", "mechanism", "classification", "counted_commitment", "justification"],
        "properties": {
          "recovery_id": {"type": "string", "minLength": 1},
          "mechanism": {"enum": ["alias", "metadata", "compiler_hidden_state", "verifier_assumption", "runtime_interpreter", "evaluator_repair", "external_operator_knowledge", "exception_policy", "unavailable_trace_information"]},
          "classification": {"enum": ["rejected_hidden_recovery", "accepted_counted_recovery", "no_recovery_present", "unknown"]},
          "counted_commitment": {"type": "boolean"},
          "justification": {"type": "string", "minLength": 20}
        }
      }
    },
    "addition_search_results": {
      "type": "array",
      "minItems": 10,
      "maxItems": 10,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["hypothesis", "classification", "covered_by_axes", "general_or_domain_specific", "justification"],
        "properties": {
          "hypothesis": {"enum": ["resource_and_computational_bounds", "agency_authorship_responsibility", "uncertainty_calibration", "social_authority_and_institutional_role", "spatial_environmental_embedding", "representational_granularity", "type_creation_and_ontology_change", "counterfactual_causal_intervention_structure", "privacy_public_private_commitments", "termination_liveness_open_endedness"]},
          "classification": {"enum": ["already_subsumed", "axis_clarification_required", "candidate_new_axis", "domain_specific", "irrelevant", "unresolved"]},
          "covered_by_axes": {"type": "array", "items": {"enum": ["P1", "P2", "P3", "P4", "P5", "P6", "P7", "P8"]}},
          "general_or_domain_specific": {"enum": ["general", "domain_specific", "irrelevant", "unresolved"]},
          "justification": {"type": "string", "minLength": 20}
        }
      }
    },
    "P8_classification": {
      "type": "object",
      "additionalProperties": false,
      "required": ["classification", "protected_distinction", "independent_variation_argument", "removal_effect", "theorem_implication", "revision_counterexample"],
      "properties": {
        "classification": {"enum": ["ordinary_preservation_coordinate", "cross_cutting_evidential_qualifier", "separate_evidence_contract", "axis_revision_required", "unresolved"]},
        "protected_distinction": {"type": "string", "minLength": 20},
        "independent_variation_argument": {"type": "string", "minLength": 20},
        "removal_effect": {"type": "string", "minLength": 20},
        "theorem_implication": {"type": "string", "minLength": 20},
        "revision_counterexample": {"type": "string", "minLength": 20}
      }
    },
    "deviations": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["deviation_id", "description", "materiality", "effect_on_result"],
        "properties": {
          "deviation_id": {"type": "string", "minLength": 1},
          "description": {"type": "string", "minLength": 1},
          "materiality": {"enum": ["none", "nonmaterial", "material", "unresolved"]},
          "effect_on_result": {"type": "string"}
        }
      }
    },
    "nonclaim_acknowledgements": {
      "type": "array",
      "minItems": 5,
      "items": {"type": "string", "minLength": 10}
    },
    "submitted_at": {"type": "string", "format": "date-time"}
  }
}
