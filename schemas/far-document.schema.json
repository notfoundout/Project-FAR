{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://project-far.local/schemas/far-document.schema.json",
  "title": "Project FAR FARDocument external IR document",
  "description": "Canonical external FAR IR interchange contract for far-ir/1.0.",
  "type": "object",
  "additionalProperties": false,
  "required": ["format_version", "id", "investigation"],
  "properties": {
    "format_version": {"const": "far-ir/1.0"},
    "id": {"$ref": "#/$defs/Identifier"},
    "investigation": {"$ref": "#/$defs/Investigation"},
    "representations": {"type": "array", "items": {"$ref": "#/$defs/Representation"}},
    "structures": {"type": "array", "items": {"$ref": "#/$defs/RepresentationalStructure"}},
    "interpretations": {"type": "array", "items": {"$ref": "#/$defs/Interpretation"}},
    "claims": {"type": "array", "items": {"$ref": "#/$defs/Claim"}},
    "assumptions": {"type": "array", "items": {"$ref": "#/$defs/Assumption"}},
    "evidence": {"type": "array", "items": {"$ref": "#/$defs/Evidence"}},
    "operations": {"type": "array", "items": {"$ref": "#/$defs/Operation"}},
    "reasoning_steps": {"type": "array", "items": {"$ref": "#/$defs/ReasoningStep"}},
    "dependencies": {"type": "array", "items": {"$ref": "#/$defs/Dependency"}},
    "proofs": {"type": "array", "items": {"$ref": "#/$defs/Proof"}},
    "graph": {"oneOf": [{"$ref": "#/$defs/ReasoningGraph"}, {"type": "null"}]},
    "source": {"oneOf": [{"$ref": "#/$defs/SourceLocation"}, {"type": "null"}]},
    "metadata": {"$ref": "#/$defs/Metadata"},
    "extensions": {"$ref": "#/$defs/Extensions"}
  },
  "$defs": {
    "Identifier": {"type": "string", "pattern": "^[A-Za-z][A-Za-z0-9_.:-]*$"},
    "Metadata": {"type": "object", "additionalProperties": true},
    "Extensions": {"type": "object", "propertyNames": {"pattern": "^[A-Za-z][A-Za-z0-9_.:-]*$"}, "additionalProperties": true},
    "SourceLocation": {"type": "object", "additionalProperties": false, "required": ["source"], "properties": {"source": {"type":"string", "minLength":1}, "line": {"type":"integer", "minimum":1}, "column": {"type":"integer", "minimum":1}, "end_line": {"type":"integer", "minimum":1}, "end_column": {"type":"integer", "minimum":1}}},
    "Reference": {"type":"object", "additionalProperties": false, "required":["identifier"], "properties":{"identifier":{"$ref":"#/$defs/Identifier"}, "expected_kind":{"oneOf":[{"enum":["representation","structure","interpretation","investigation","claim","assumption","evidence","operation","reasoning_step","dependency","proof"]},{"type":"null"}]}, "source":{"oneOf":[{"$ref":"#/$defs/SourceLocation"},{"type":"null"}]}}},
    "Common": {"type":"object", "required":["id","kind"], "properties":{"id":{"$ref":"#/$defs/Identifier"}, "kind":{"type":"string"}, "source":{"oneOf":[{"$ref":"#/$defs/SourceLocation"},{"type":"null"}]}, "metadata":{"$ref":"#/$defs/Metadata"}, "extensions":{"$ref":"#/$defs/Extensions"}}},
    "Representation": {"allOf":[{"$ref":"#/$defs/Common"},{"type":"object", "additionalProperties": false, "required":["id","kind","content"], "properties":{"id":{"$ref":"#/$defs/Identifier"},"kind":{"const":"representation"},"content":{"type":"string","minLength":1},"source":{"oneOf":[{"$ref":"#/$defs/SourceLocation"},{"type":"null"}]},"metadata":{"$ref":"#/$defs/Metadata"},"extensions":{"$ref":"#/$defs/Extensions"}}}]},
    "RepresentationalStructure": {"type":"object", "additionalProperties": false, "required":["id","kind","description","representations"], "properties":{"id":{"$ref":"#/$defs/Identifier"},"kind":{"const":"structure"},"description":{"type":"string","minLength":1},"representations":{"type":"array","items":{"$ref":"#/$defs/Reference"}},"source":{"oneOf":[{"$ref":"#/$defs/SourceLocation"},{"type":"null"}]},"metadata":{"$ref":"#/$defs/Metadata"},"extensions":{"$ref":"#/$defs/Extensions"}}},
    "Interpretation": {"type":"object", "additionalProperties": false, "required":["id","kind","representation","meaning"], "properties":{"id":{"$ref":"#/$defs/Identifier"},"kind":{"const":"interpretation"},"representation":{"$ref":"#/$defs/Reference"},"meaning":{"type":"string","minLength":1},"source":{"oneOf":[{"$ref":"#/$defs/SourceLocation"},{"type":"null"}]},"metadata":{"$ref":"#/$defs/Metadata"},"extensions":{"$ref":"#/$defs/Extensions"}}},
    "Investigation": {"type":"object", "additionalProperties": false, "required":["id","kind","question"], "properties":{"id":{"$ref":"#/$defs/Identifier"},"kind":{"const":"investigation"},"question":{"type":"string","minLength":1},"scope":{"type":"string"},"source":{"oneOf":[{"$ref":"#/$defs/SourceLocation"},{"type":"null"}]},"metadata":{"$ref":"#/$defs/Metadata"},"extensions":{"$ref":"#/$defs/Extensions"}}},
    "Claim": {"$ref":"#/$defs/StatementObjectClaim"},
    "Assumption": {"$ref":"#/$defs/StatementObjectAssumption"},
    "StatementObjectClaim": {"type":"object", "additionalProperties": false, "required":["id","kind","statement"], "properties":{"id":{"$ref":"#/$defs/Identifier"},"kind":{"const":"claim"},"statement":{"type":"string","minLength":1},"source":{"oneOf":[{"$ref":"#/$defs/SourceLocation"},{"type":"null"}]},"metadata":{"$ref":"#/$defs/Metadata"},"extensions":{"$ref":"#/$defs/Extensions"}}},
    "StatementObjectAssumption": {"type":"object", "additionalProperties": false, "required":["id","kind","statement"], "properties":{"id":{"$ref":"#/$defs/Identifier"},"kind":{"const":"assumption"},"statement":{"type":"string","minLength":1},"source":{"oneOf":[{"$ref":"#/$defs/SourceLocation"},{"type":"null"}]},"metadata":{"$ref":"#/$defs/Metadata"},"extensions":{"$ref":"#/$defs/Extensions"}}},
    "Evidence": {"type":"object", "additionalProperties": false, "required":["id","kind","description"], "properties":{"id":{"$ref":"#/$defs/Identifier"},"kind":{"const":"evidence"},"description":{"type":"string","minLength":1},"cites":{"type":"array","items":{"$ref":"#/$defs/Reference"}},"source":{"oneOf":[{"$ref":"#/$defs/SourceLocation"},{"type":"null"}]},"metadata":{"$ref":"#/$defs/Metadata"},"extensions":{"$ref":"#/$defs/Extensions"}}},
    "Operation": {"type":"object", "additionalProperties": false, "required":["id","kind","description"], "properties":{"id":{"$ref":"#/$defs/Identifier"},"kind":{"const":"operation"},"description":{"type":"string","minLength":1},"inputs":{"type":"array","items":{"$ref":"#/$defs/Reference"}},"outputs":{"type":"array","items":{"$ref":"#/$defs/Reference"}},"source":{"oneOf":[{"$ref":"#/$defs/SourceLocation"},{"type":"null"}]},"metadata":{"$ref":"#/$defs/Metadata"},"extensions":{"$ref":"#/$defs/Extensions"}}},
    "ReasoningStep": {"type":"object", "additionalProperties": false, "required":["id","kind","order","rationale"], "properties":{"id":{"$ref":"#/$defs/Identifier"},"kind":{"const":"reasoning_step"},"order":{"type":"integer","minimum":0},"operation":{"oneOf":[{"$ref":"#/$defs/Reference"},{"type":"null"}]},"premises":{"type":"array","items":{"$ref":"#/$defs/Reference"}},"conclusions":{"type":"array","items":{"$ref":"#/$defs/Reference"}},"rationale":{"type":"string","minLength":1},"source":{"oneOf":[{"$ref":"#/$defs/SourceLocation"},{"type":"null"}]},"metadata":{"$ref":"#/$defs/Metadata"},"extensions":{"$ref":"#/$defs/Extensions"}}},
    "Dependency": {"type":"object", "additionalProperties": false, "required":["id","kind","source_ref","target_ref","relation"], "properties":{"id":{"$ref":"#/$defs/Identifier"},"kind":{"const":"dependency"},"source_ref":{"$ref":"#/$defs/Reference"},"target_ref":{"$ref":"#/$defs/Reference"},"relation":{"type":"string","minLength":1},"source":{"oneOf":[{"$ref":"#/$defs/SourceLocation"},{"type":"null"}]},"metadata":{"$ref":"#/$defs/Metadata"},"extensions":{"$ref":"#/$defs/Extensions"}}},
    "Proof": {"type":"object", "additionalProperties": false, "required":["id","kind","claim"], "properties":{"id":{"$ref":"#/$defs/Identifier"},"kind":{"const":"proof"},"claim":{"$ref":"#/$defs/Reference"},"steps":{"type":"array","items":{"$ref":"#/$defs/Reference"}},"assumptions":{"type":"array","items":{"$ref":"#/$defs/Reference"}},"evidence":{"type":"array","items":{"$ref":"#/$defs/Reference"}},"source":{"oneOf":[{"$ref":"#/$defs/SourceLocation"},{"type":"null"}]},"metadata":{"$ref":"#/$defs/Metadata"},"extensions":{"$ref":"#/$defs/Extensions"}}},
    "GraphNode": {"type":"object", "additionalProperties": false, "required":["id","kind"], "properties":{"id":{"$ref":"#/$defs/Identifier"},"kind":{"enum":["representation","structure","interpretation","investigation","claim","assumption","evidence","operation","reasoning_step","proof"]},"source":{"oneOf":[{"$ref":"#/$defs/SourceLocation"},{"type":"null"}]},"metadata":{"$ref":"#/$defs/Metadata"},"extensions":{"$ref":"#/$defs/Extensions"}}},
    "GraphEdge": {"type":"object", "additionalProperties": false, "required":["id","kind","source_ref","target_ref"], "properties":{"id":{"$ref":"#/$defs/Identifier"},"kind":{"enum":["depends_on","supports","contradicts","interprets","scopes","transforms","derives","cites","records"]},"source_ref":{"$ref":"#/$defs/Reference"},"target_ref":{"$ref":"#/$defs/Reference"},"provenance":{"oneOf":[{"$ref":"#/$defs/SourceLocation"},{"type":"null"}]},"metadata":{"$ref":"#/$defs/Metadata"},"extensions":{"$ref":"#/$defs/Extensions"}}},
    "ReasoningGraph": {"type":"object", "additionalProperties": false, "properties":{"nodes":{"type":"array","items":{"$ref":"#/$defs/GraphNode"}},"edges":{"type":"array","items":{"$ref":"#/$defs/GraphEdge"}},"metadata":{"$ref":"#/$defs/Metadata"},"extensions":{"$ref":"#/$defs/Extensions"}}}
  }
}
